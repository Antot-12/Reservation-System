# Production Environment Variables for Backend (Oracle Cloud)
# Copy this file to .env.production and fill in your values

# Database (Docker internal network)
DATABASE_URL=postgresql://rezervation:YOUR_DB_PASSWORD@postgres:5432/rezervation

# Admin Credentials
ADMIN_USERNAME=admin
# Generate hash: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your_password'))"
ADMIN_PASSWORD_HASH=$2b$12$GENERATE_YOUR_HASH_HERE
ADMIN_PHONE=+380501234567

# Twilio SMS (optional - for OTP via SMS)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# SMTP Email - Required for notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com
DOCTOR_EMAIL=doctor@example.com

# Security - CHANGE THESE IN PRODUCTION!
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GENERATE_A_STRONG_RANDOM_KEY
BOT_SECRET=GENERATE_ANOTHER_STRONG_KEY

# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
SESSION_EXPIRY_HOURS=12
SKIP_OTP_VERIFICATION=false
SKIP_USER_OTP_VERIFICATION=false

# Telegram Bot (Docker internal network)
TELEGRAM_BOT_URL=http://telegram_bot:5000

# Business Logic
MAX_BOOKINGS_PER_USER=6
CANCELLATION_HOURS_BEFORE=48
BOOKING_MONTHS_AHEAD=2

# Timezone
TZ=Europe/Kiev

# Frontend URL (for emails/links)
FRONTEND_URL=https://your-app.vercel.app

# CORS Origins - Your Vercel URL(s), comma-separated
CORS_ORIGINS=https://your-app.vercel.app,https://www.your-domain.com

# Redis (Docker internal network)
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true
CACHE_TTL_SECONDS=300

# Monitoring
ENVIRONMENT=production
ENABLE_METRICS=true
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
