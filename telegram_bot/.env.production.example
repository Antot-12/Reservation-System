# Production Environment Variables for Telegram Bot
# Copy this to .env.production and fill in real values

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Database
DATABASE_URL=postgresql://rezervation:password@postgres:5432/rezervation

# Backend API URL (internal Docker network)
BACKEND_URL=http://backend:8000

# Timezone
TZ=Europe/Kiev
